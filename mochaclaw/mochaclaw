#!/usr/bin/env node

// MochaClaw – Lightweight Local AI Agent (CommonJS, custom ASCII banner)
// All state in MOCHASOUL.md | Enhanced CLI with help & error handling

const fs = require('fs');
const path = require('path');
const readline = require('readline/promises');
const { execSync } = require('child_process');
const axios = require('axios');
require('dotenv').config();

