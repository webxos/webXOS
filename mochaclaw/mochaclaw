// 10. Main
async function main() {
  const args = process.argv.slice(2);
  if (args.length === 0) {
    const rl = readline.createInterface({
      input: process.stdin,
      output: process.stdout,
      prompt: `${colors.latte}mocha>${colors.reset} `
    });

    showBanner();
    console.log(`${colors.green}Type /help for available commands.${colors.reset}\n`);

    if (BACKEND === 'ollama') {
      try {
        await axios.get(`${OLLAMA_URL}/api/tags`);
      } catch (error) {
        console.error(`${colors.red}⚠ Warning: Cannot connect to Ollama.${colors.reset}`);
        console.error(`${colors.yellow}Make sure Ollama is running: 'ollama serve'${colors.reset}`);
        console.error(`${colors.yellow}You can also switch to Transformers.js backend by setting INFERENCE_BACKEND=transformers in .env${colors.reset}\n`);
      }
    }

    rl.prompt();

    rl.on('line', async (line) => {
      const input = line.trim();
      if (!input) {
        rl.prompt();
        return;
      }

      if (input.startsWith('/')) {
        const cmd = input.slice(1).toLowerCase();
        if (cmd === 'help' || cmd === 'h') {
          showHelp();
        } else if (cmd === 'guide' || cmd === 'g') {
          showGuide();
        } else if (cmd === 'memory' || cmd === 'm') {
          const soul = readSoul();
          console.log(`${colors.cyan}Current Memory:${colors.reset}\n${soul.memory || '(empty)'}`);
        } else if (cmd === 'journal' || cmd === 'j') {
          const soul = readSoul();
          const lastEntries = soul.journal.split('---').slice(-3).join('---');
          console.log(`${colors.cyan}Recent Journal:${colors.reset}\n${lastEntries || '(empty)'}`);
        } else if (cmd === 'tools' || cmd === 't') {
          showTools();
        } else if (cmd === 'kb' || cmd === 'k') {
          await showKBSummary();
        } else if (cmd === 'exit' || cmd === 'quit') {
          console.log(`${colors.green}Goodbye!${colors.reset}`);
          rl.close();
          return;
        } else {
          console.log(`${colors.red}Unknown command. Type /help for available commands.${colors.reset}`);
        }
        rl.prompt();
        return;
      }

      console.log(`${colors.yellow}MochaClaw thinking...${colors.reset}`);
      try {
        const result = await runAgentStep(input);
        if (result.answer) {
          console.log(`\n${colors.green}Agent:${colors.reset} ${result.answer}\n`);
        } else if (result.observation) {
          console.log(`\n${colors.green}Tool Result:${colors.reset} ${JSON.stringify(result.observation, null, 2)}\n`);
        }
      } catch (error) {
        console.error(`${colors.red}Error:${colors.reset} ${error.message}`);
      }
      rl.prompt();
    });

    rl.on('close', () => {
      process.exit(0);
    });
  } else {
    const query = args.join(' ');
    try {
      const result = await runAgentStep(query);
      if (result.answer) {
        console.log(result.answer);
      } else if (result.observation) {
        console.log(JSON.stringify(result.observation, null, 2));
      }
    } catch (error) {
      console.error(`${colors.red}Error:${colors.reset} ${error.message}`);
      process.exit(1);
    }
  }
}

main().catch(console.error);
