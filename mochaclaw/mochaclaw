// ----------------------------------------------------------------------
// 3. Soul File Management
function readSoul() {
  if (!fs.existsSync(SOUL_FILE)) {
    const defaultSoul = `# Persona
You are MochaClaw, a privacy-first AI assistant running locally on Debian.
You have access to these tools: run_command, read_file, write_file, update_memory.
When you need to perform an action, output exactly:

Action: toolName({ "arg": "value" })

Then wait for the observation. Otherwise, you may answer directly.

# Memory
- Initialized on first run.

# Journal
`;
    fs.writeFileSync(SOUL_FILE, defaultSoul);
    return { persona: defaultSoul.split('# Memory')[0].trim(), memory: '', journal: '' };
  }

  const content = fs.readFileSync(SOUL_FILE, 'utf-8');
  const personaMatch = content.match(/# Persona\n([\s\S]*?)(?=\n# Memory|$)/);
  const memoryMatch = content.match(/# Memory\n([\s\S]*?)(?=\n# Journal|$)/);
  const journalMatch = content.match(/# Journal\n([\s\S]*?)$/);

  return {
    persona: personaMatch ? personaMatch[1].trim() : '',
    memory: memoryMatch ? memoryMatch[1].trim() : '',
    journal: journalMatch ? journalMatch[1].trim() : ''
  };
}

function updateMemory(newEntry) {
  const content = fs.readFileSync(SOUL_FILE, 'utf-8');
  const memorySection = content.match(/# Memory\n([\s\S]*?)(?=\n# Journal|$)/);
  if (memorySection) {
    const updatedMemory = memorySection[1] + `\n- ${newEntry}`;
    const newContent = content.replace(/# Memory\n([\s\S]*?)(?=\n# Journal|$)/, `# Memory\n${updatedMemory}`);
    fs.writeFileSync(SOUL_FILE, newContent);
  } else {
    fs.appendFileSync(SOUL_FILE, `\n# Memory\n- ${newEntry}\n`);
  }
}

function appendToJournal(thought, action, observation) {
  const entry = `\n## Thought\n${thought}\n\n**Action:** ${action}\n\n**Observation:** ${observation}\n---\n`;
  const content = fs.readFileSync(SOUL_FILE, 'utf-8');
  if (content.includes('# Journal')) {
    const newContent = content.replace(/(# Journal\n)/, `$1${entry}`);
    fs.writeFileSync(SOUL_FILE, newContent);
  } else {
    fs.appendFileSync(SOUL_FILE, `\n# Journal\n${entry}`);
  }
}

// ----------------------------------------------------------------------
// 4. Tool Registry
const tools = {
  run_command: ({ command }) => {
    try {
      const output = execSync(command, { encoding: 'utf-8', timeout: 5000 });
      return { success: true, output };
    } catch (error) {
      return { success: false, output: error.message };
    }
  },
  read_file: ({ path: filePath }) => {
    try {
      const data = fs.readFileSync(filePath, 'utf-8');
      return { success: true, data };
    } catch (e) {
      return { success: false, error: e.message };
    }
  },
  write_file: ({ path: filePath, content }) => {
    try {
      fs.writeFileSync(filePath, content);
      return { success: true };
    } catch (e) {
      return { success: false, error: e.message };
    }
  },
  update_memory: ({ content }) => {
    updateMemory(content);
    return { success: true, status: 'Memory updated' };
  }
};

// ----------------------------------------------------------------------
// 5. Inference Backend
async function generateOllama(prompt, options = {}) {
  try {
    const response = await axios.post(`${OLLAMA_URL}/api/generate`, {
      model: OLLAMA_MODEL,
      prompt,
      stream: false,
      options: {
        num_predict: options.max_new_tokens || 256,
        stop: options.stop_sequence ? [options.stop_sequence] : undefined,
      }
    });
    return response.data.response;
  } catch (error) {
    if (error.code === 'ECONNREFUSED') {
      throw new Error(`Cannot connect to Ollama at ${OLLAMA_URL}. Is Ollama running? (Try 'ollama serve')`);
    }
    throw error;
  }
}

async function generate(prompt, options = {}) {
  if (BACKEND === 'ollama') {
    return generateOllama(prompt, options);
  } else {
    // Transformers.js fallback
    const { pipeline, env } = require('@xenova/transformers');
    env.allowRemoteModels = true;
    console.error(`${colors.yellow}Loading Transformers.js model (first time may take a while)...${colors.reset}`);
    const pipe = await pipeline('text-generation', process.env.TRANSFORMERS_MODEL || 'Xenova/phi-3-mini-4k-instruct');
    const result = await pipe(prompt, {
      max_new_tokens: options.max_new_tokens || 256,
      // stop_sequence is not supported; use eos_token_id if needed
    });
    return result[0].generated_text;
  }
}

// ----------------------------------------------------------------------
// 6. Agent Loop (with fixed regex)
async function runAgentStep(userInput) {
  const soul = readSoul();
  const context = `${soul.persona}\n\nRecent memory:\n${soul.memory.slice(-500)}\n\nUser: ${userInput}\nThought:`;

  const response = await generate(context, { max_new_tokens: 256, stop_sequence: 'Observation:' });

  // Fixed regex: capture only up to first closing parenthesis of the JSON object
  const actionMatch = response.match(/Action:\s*(\w+)\s*\(\s*({[^}]*})\s*\)/s);
  if (actionMatch) {
    const [_, toolName, argsJson] = actionMatch;
    try {
      const args = JSON.parse(argsJson);
      const tool = tools[toolName];
      if (!tool) throw new Error(`Tool ${toolName} not found`);
      const observation = tool(args);
      const obsStr = JSON.stringify(observation);
      appendToJournal(response, toolName, obsStr);
      return { thought: response, action: toolName, observation };
    } catch (e) {
      const errorObs = { error: e.message };
      appendToJournal(response, toolName, JSON.stringify(errorObs));
      return { thought: response, action: toolName, observation: errorObs };
    }
  }

  appendToJournal(response, 'none', '');
  return { answer: response };
}

