// ----------------------------------------------------------------------
// 3. Soul File Management (unchanged)
function readSoul() {
  if (!fs.existsSync(SOUL_FILE)) {
    const defaultSoul = `# Persona
You are MochaClaw, a privacy‑first AI assistant running locally on Debian.
You have access to tools that let you interact with the system.

# Memory
- Initialized on first run.

# Journal
`;
    fs.writeFileSync(SOUL_FILE, defaultSoul);
    return { persona: defaultSoul.split('# Memory')[0].trim(), memory: '', journal: '' };
  }

  const content = fs.readFileSync(SOUL_FILE, 'utf-8');
  const personaMatch = content.match(/# Persona\n([\s\S]*?)(?=\n# Memory|$)/);
  const memoryMatch = content.match(/# Memory\n([\s\S]*?)(?=\n# Journal|$)/);
  const journalMatch = content.match(/# Journal\n([\s\S]*?)$/);

  return {
    persona: personaMatch ? personaMatch[1].trim() : '',
    memory: memoryMatch ? memoryMatch[1].trim() : '',
    journal: journalMatch ? journalMatch[1].trim() : ''
  };
}

function updateMemory(newEntry) {
  const content = fs.readFileSync(SOUL_FILE, 'utf-8');
  const memorySection = content.match(/# Memory\n([\s\S]*?)(?=\n# Journal|$)/);
  if (memorySection) {
    const updatedMemory = memorySection[1] + `\n- ${newEntry}`;
    const newContent = content.replace(/# Memory\n([\s\S]*?)(?=\n# Journal|$)/, `# Memory\n${updatedMemory}`);
    fs.writeFileSync(SOUL_FILE, newContent);
  } else {
    fs.appendFileSync(SOUL_FILE, `\n# Memory\n- ${newEntry}\n`);
  }
}

function appendToJournal(thought, action, observation) {
  const entry = `\n## Thought\n${thought}\n\n**Action:** ${action}\n\n**Observation:** ${observation}\n---\n`;
  const content = fs.readFileSync(SOUL_FILE, 'utf-8');
  if (content.includes('# Journal')) {
    const newContent = content.replace(/(# Journal\n)/, `$1${entry}`);
    fs.writeFileSync(SOUL_FILE, newContent);
  } else {
    fs.appendFileSync(SOUL_FILE, `\n# Journal\n${entry}`);
  }
}

// ----------------------------------------------------------------------
// 4. Tool Registry with argument normalization & validation
const REQUIRED_ARGS = {
  run_command: ['command'],
  read_file: ['path'],
  write_file: ['path', 'content'],
  update_memory: ['content'],
  markdown_kb: ['action']   // 'action' is always required
};

function normalizeArgs(toolName, args) {
  if ((toolName === 'read_file' || toolName === 'write_file') && args.file !== undefined && args.path === undefined) {
    args.path = args.file;
  }
  return args;
}

function validateArgs(toolName, args) {
  const required = REQUIRED_ARGS[toolName];
  if (!required) return { valid: true, args };
  const missing = required.filter(key => args[key] === undefined);
  if (missing.length > 0) {
    return { valid: false, error: `Missing required argument(s): ${missing.join(', ')}` };
  }
  return { valid: true, args };
}

// Import the KB module (will be loaded when the tool is first used)
let kb = null;
function getKB() {
  if (!kb) {
    kb = require('./tools/markdown_kb');
  }
  return kb;
}

const tools = {
  run_command: ({ command }) => {
    try {
      const output = execSync(command, { encoding: 'utf-8', timeout: 5000 });
      return { success: true, output };
    } catch (error) {
      return { success: false, output: error.message };
    }
  },
  read_file: ({ path: filePath }) => {
    try {
      const data = fs.readFileSync(filePath, 'utf-8');
      return { success: true, data };
    } catch (e) {
      return { success: false, error: e.message };
    }
  },
  write_file: ({ path: filePath, content }) => {
    try {
      fs.writeFileSync(filePath, content);
      return { success: true };
    } catch (e) {
      return { success: false, error: e.message };
    }
  },
  update_memory: ({ content }) => {
    updateMemory(content);
    return { success: true, status: 'Memory updated' };
  },
  markdown_kb: (args) => {
    const { action, ...params } = args;
    const kbMod = getKB();
    try {
      let result;
      switch (action) {
        case 'search':
          result = kbMod.search(params.query, params.limit || 5);
          break;
        case 'write':
          if (!params.title || !params.content) throw new Error('Missing title or content for write action');
          result = kbMod.writeNote(params.title, params.content);
          break;
        case 'read':
          if (params.path) {
            result = kbMod.readNoteByPath(params.path);
          } else if (params.title) {
            result = kbMod.readNoteByTitle(params.title);
          } else {
            throw new Error('Either path or title required for read action');
          }
          break;
        case 'reindex':
          result = kbMod.rebuildIndex();
          break;
        case 'list':
          result = kbMod.listNotes();
          break;
        default:
          throw new Error(`Unknown action: ${action}. Use search, write, read, reindex, or list.`);
      }
      return { success: true, result };
    } catch (e) {
      return { success: false, error: e.message };
    }
  }
};

// ----------------------------------------------------------------------
// 5. Inference Backend (unchanged)
async function generateOllama(prompt, options = {}) {
  try {
    const response = await axios.post(`${OLLAMA_URL}/api/generate`, {
      model: OLLAMA_MODEL,
      prompt,
      stream: false,
      options: {
        num_predict: options.max_new_tokens || 256,
        stop: options.stop_sequence ? [options.stop_sequence] : undefined,
      }
    });
    return response.data.response;
  } catch (error) {
    if (error.code === 'ECONNREFUSED') {
      throw new Error(`Cannot connect to Ollama at ${OLLAMA_URL}. Is Ollama running? (Try 'ollama serve')`);
    }
    throw error;
  }
}

async function generate(prompt, options = {}) {
  if (BACKEND === 'ollama') {
    return generateOllama(prompt, options);
  } else {
    const { pipeline, env } = require('@xenova/transformers');
    env.allowRemoteModels = true;
    console.error(`${colors.yellow}Loading Transformers.js model (first time may take a while)...${colors.reset}`);
    const pipe = await pipeline('text-generation', process.env.TRANSFORMERS_MODEL || 'Xenova/phi-3-mini-4k-instruct');
    const result = await pipe(prompt, {
      max_new_tokens: options.max_new_tokens || 256,
    });
    return result[0].generated_text;
  }
}

// ----------------------------------------------------------------------
// 6. Action parsing (robust)
function parseAction(text) {
  const match = text.match(/Action:\s*(\w+)\s*\(\s*(\{.*?\})\s*\)/s);
  if (!match) return null;
  const [_, toolName, argsStr] = match;
  try {
    const args = JSON.parse(argsStr);
    return { toolName, args };
  } catch (e) {
    return null;
  }
}

// ----------------------------------------------------------------------
// 7. Build ReAct prompt (include KB tool description)
function buildPrompt(persona, memory, userInput) {
  const toolDescriptions = `
You have access to the following tools:
- run_command({ "command": "string" }) – Execute a shell command.
- read_file({ "path": "string" }) – Read a file's contents. (You may also use "file" as the key.)
- write_file({ "path": "string", "content": "string" }) – Write content to a file.
- update_memory({ "content": "string" }) – Store a fact in long-term memory.
- markdown_kb({ "action": "search", "query": "search terms", "limit": 5 }) – Search your Markdown knowledge base.
- markdown_kb({ "action": "write", "title": "Note title", "content": "Markdown content" }) – Create or update a note.
- markdown_kb({ "action": "read", "title": "Note title" }) – Read a note by its title.
- markdown_kb({ "action": "read", "path": "knowledge/some.md" }) – Read a note by file path.
- markdown_kb({ "action": "reindex" }) – Rebuild the search index.
- markdown_kb({ "action": "list" }) – List all notes in the knowledge base.

When you need to use a tool, output exactly:
Action: toolName({ "arg": "value" })

Otherwise, answer directly.

Example:
User: What notes do I have about AI?
Thought: I should search my knowledge base for "AI".
Action: markdown_kb({ "action": "search", "query": "AI" })
Observation: {"success":true,"result":[{"title":"AI ideas","snippet":"..."}]}
Answer: You have a note titled "AI ideas" that mentions...

Now continue the conversation.
`;

  const system = `${persona}\n\n${toolDescriptions}\nRecent memory:\n${memory.slice(-500)}`;
  return `${system}\n\nUser: ${userInput}\nThought:`;
}

// ----------------------------------------------------------------------
// 8. Agent Step
async function runAgentStep(userInput) {
  const soul = readSoul();
  const prompt = buildPrompt(soul.persona, soul.memory, userInput);

  const response = await generate(prompt, { max_new_tokens: 256, stop_sequence: 'Observation:' });

  const parsed = parseAction(response);
  if (parsed) {
    let { toolName, args } = parsed;
    args = normalizeArgs(toolName, args);
    const validation = validateArgs(toolName, args);
    if (!validation.valid) {
      const errorObs = { error: `Tool call validation failed: ${validation.error}` };
      appendToJournal(response, toolName, JSON.stringify(errorObs));
      return { thought: response, action: toolName, observation: errorObs };
    }

    const tool = tools[toolName];
    if (!tool) {
      const errorObs = { error: `Tool "${toolName}" not found` };
      appendToJournal(response, toolName, JSON.stringify(errorObs));
      return { thought: response, action: toolName, observation: errorObs };
    }

    try {
      const observation = tool(args);
      const obsStr = JSON.stringify(observation);
      appendToJournal(response, toolName, obsStr);
      return { thought: response, action: toolName, observation };
    } catch (e) {
      const errorObs = { error: e.message };
      appendToJournal(response, toolName, JSON.stringify(errorObs));
      return { thought: response, action: toolName, observation: errorObs };
    }
  }

  appendToJournal(response, 'none', '');
  return { answer: response };
}

